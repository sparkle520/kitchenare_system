{
  "private": "true",
  "name": "@tencent/tdesign-vue-next-starter",
  "version": "0.13.0",
  "description": "Ruoyi-Tdesign多租户管理系统",
  "type": "module",
  "scripts": {
    "dev:mock": "vite --open --mode mock",
    "dev": "vite --open --mode development",
    "dev:linux": "vite --mode development",
    "build:test": "vite build --mode test --minify false",
    "build": "vite build --mode release",
    "build:type": "vue-tsc --noEmit",
    "build:site": "vue-tsc --noEmit && vite build --mode site",
    "preview": "vite preview",
    "lint": "eslint --ext .vue,.js,.jsx,.ts,.tsx ./src --max-warnings 0",
    "lint:fix": "eslint --ext .vue,.js,jsx,.ts,.tsx ./src --max-warnings 0 --fix",
    "stylelint": "stylelint src/**/*.{html,vue,css,sass,less}",
    "stylelint:fix": "stylelint --fix src/**/*.{html,vue,css,sass,less}",
    "site:preview": "npm run build && cp -r dist _site",
    "test": "echo \"no test specified,work in process\"",
    "test:coverage": "echo \"no test:coverage specified,work in process\""
  },
  "dependencies": {
    "@tinymce/tinymce-vue": "~5.1.1",
    "@vueuse/core": "^14.2.1",
    "axios": "~1.15.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "echarts": "5.4.3",
    "file-saver": "^2.0.5",
    "fuse.js": "^7.1.0",
    "image-conversion": "^2.1.1",
    "js-cookie": "^3.0.5",
    "jsencrypt": "3.3.2",
    "lodash": "^4.18.1",
    "nprogress": "^0.2.0",
    "pinia": "~3.0.4",
    "pinia-plugin-persistedstate": "~4.7.1",
    "prismjs": "^1.30.0",
    "qrcode.vue": "^3.8.1",
    "qs": "^6.15.1",
    "tdesign-icons-vue-next": "0.4.4",
    "tdesign-vue-next": "1.19.1",
    "tinymce": "^7.8.0",
    "tvision-color": "^1.6.0",
    "vue": "~3.5.32",
    "vue-cropper": "^1.1.4",
    "vue-i18n": "11.1.3",
    "vue-json-pretty": "^2.6.0",
    "vue-router": "~4.6.4",
    "vue-types": "6.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/crypto-js": "^4.2.2",
    "@types/echarts": "^4.9.22",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/nprogress": "^0.2.3",
    "@types/prismjs": "^1.26.6",
    "@types/qs": "^6.9.18",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitejs/plugin-vue-jsx": "^4.1.2",
    "@vue/compiler-sfc": "~3.5.18",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "~9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue-scoped-css": "^2.9.0",
    "globals": "^16.0.0",
    "less": "^4.3.0",
    "lint-staged": "^15.2.2",
    "mockjs": "^1.1.0",
    "postcss-html": "^1.8.0",
    "postcss-less": "^6.0.0",
    "prettier": "^3.8.3",
    "rollup-plugin-copy": "^3.5.0",
    "rspack-resolver": "^1.3.0",
    "stylelint": "~16.26.1",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-order": "~6.0.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.26.1",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "6.3.4",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-prismjs": "^0.0.11",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "2.2.10"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,jsx,vue,ts,tsx}": [
      "prettier --write",
      "npm run lint:fix"
    ],
    "*.{html,vue,css,sass,less}": [
      "npm run stylelint:fix"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
