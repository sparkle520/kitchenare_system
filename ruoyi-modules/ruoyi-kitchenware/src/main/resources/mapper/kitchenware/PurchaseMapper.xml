<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dromara.kitchenware.mapper.PurchaseMapper">

    <resultMap id="PurchaseResult" autoMapping="true" type="org.dromara.kitchenware.domain.Purchase">
        <id property="id" column="id"/>
    </resultMap>
    <resultMap id="PurchaseResultVo" autoMapping="true" type="org.dromara.kitchenware.domain.vo.PurchaseVo">
        <id property="id" column="id"/>
    </resultMap>

    <sql id="selectPurchaseVo">
        select p.id, p.supplier_id, p.operator_id, p.total_amount, p.pay_status, p.purchase_time, p.note, p.create_by, p.create_time, p.update_by, p.update_time, p.del_flag from purchase p
    </sql>
    <select id="queryList" parameterType="org.dromara.kitchenware.domain.query.PurchaseQuery" resultMap="PurchaseResultVo">
        <include refid="selectPurchaseVo"/>
        <where>
            <if test="supplierId != null"> and p.supplier_id = #{supplierId}</if>
            <if test="operatorId != null"> and p.operator_id = #{operatorId}</if>
            <if test="totalAmount != null"> and p.total_amount = #{totalAmount}</if>
            <if test="payStatus != null"> and p.pay_status = #{payStatus}</if>
            <if test="purchaseTime != null"> and p.purchase_time = #{purchaseTime}</if>
            <if test="note != null and note != ''"> and p.note = #{note}</if>
            and p.del_flag = '0'
        </where>
    </select>

</mapper>
