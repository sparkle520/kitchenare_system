<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dromara.kitchenware.mapper.GoodsMapper">

    <resultMap id="GoodsResult" autoMapping="true" type="org.dromara.kitchenware.domain.Goods">
        <id property="id" column="id"/>
    </resultMap>
    <resultMap id="GoodsResultVo" autoMapping="true" type="org.dromara.kitchenware.domain.vo.GoodsVo">
        <id property="id" column="id"/>
    </resultMap>

    <sql id="selectGoodsVo">
        select g.id, g.category_id, g.goods_name, g.brand, g.detail, g.status, g.create_by, g.create_time, g.update_by, g.update_time, g.del_flag from goods g
    </sql>
    <select id="queryList" parameterType="org.dromara.kitchenware.domain.query.GoodsQuery" resultMap="GoodsResultVo">
        <include refid="selectGoodsVo"/>
        <where>
            <if test="categoryId != null"> and g.category_id = #{categoryId}</if>
            <if test="goodsName != null and goodsName != ''"> and g.goods_name like concat(concat('%', #{goodsName}), '%')</if>
            <if test="brand != null and brand != ''"> and g.brand = #{brand}</if>
            <if test="detail != null and detail != ''"> and g.detail = #{detail}</if>
            <if test="status != null"> and g.status = #{status}</if>
            and g.del_flag = '0'
        </where>
    </select>

</mapper>
