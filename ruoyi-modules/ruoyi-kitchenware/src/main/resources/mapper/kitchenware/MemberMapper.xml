<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.dromara.kitchenware.mapper.MemberMapper">

    <resultMap id="MemberResult" autoMapping="true" type="org.dromara.kitchenware.domain.Member">
        <id property="memberId" column="member_id"/>
    </resultMap>
    <resultMap id="MemberResultVo" autoMapping="true" type="org.dromara.kitchenware.domain.vo.MemberVo">
        <id property="memberId" column="member_id"/>
    </resultMap>

    <sql id="selectMemberVo">
        select m.member_id, m.nickname, m.mobile, m.avatar, m.password, m.balance, m.point, m.last_login_time, m.status, m.del_flag, m.create_by, m.create_time, m.update_by, m.update_time from member m
    </sql>
    <select id="queryList" parameterType="org.dromara.kitchenware.domain.query.MemberQuery" resultMap="MemberResultVo">
        <include refid="selectMemberVo"/>
        <where>
            <if test="nickname != null and nickname != ''"> and m.nickname like concat(concat('%', #{nickname}), '%')</if>
            <if test="mobile != null and mobile != ''"> and m.mobile = #{mobile}</if>
            <if test="avatar != null and avatar != ''"> and m.avatar = #{avatar}</if>
            <if test="password != null and password != ''"> and m.password = #{password}</if>
            <if test="balance != null"> and m.balance = #{balance}</if>
            <if test="point != null"> and m.point = #{point}</if>
            <if test="lastLoginTime != null"> and m.last_login_time = #{lastLoginTime}</if>
            <if test="status != null and status != ''"> and m.status = #{status}</if>
            and m.del_flag = '0'
        </where>
    </select>

</mapper>
